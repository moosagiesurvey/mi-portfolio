---
const skills = [
  { name: "React", level: 95, color: "#00f0ff" },
  { name: "TypeScript", level: 92, color: "#7b2ff7" },
  { name: "Node.js", level: 88, color: "#ff00e5" },
  { name: "Python", level: 85, color: "#00f0ff" },
  { name: "Rust", level: 70, color: "#7b2ff7" },
  { name: "GraphQL", level: 82, color: "#ff00e5" },
  { name: "PostgreSQL", level: 78, color: "#00f0ff" },
  { name: "Docker", level: 80, color: "#7b2ff7" },
];
---

<section id="skills" class="relative py-24 md:py-32 px-6">
  <div class="max-w-6xl mx-auto">
    <div data-aos="fade-up" class="text-center mb-16">
      <span class="text-nexus-cyan text-sm tracking-widest font-medium mb-4 block">✦ EXPERTISE</span>
      <h2 class="text-4xl md:text-5xl font-display font-bold text-white mb-4">
        Tech <span class="gradient-text-alt">Stack</span>
      </h2>
      <p class="text-nexus-gray max-w-xl mx-auto">
        Tools and technologies I wield to bring ideas to life.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
      {skills.map((skill, index) => (
        <div
          data-aos="fade-up"
          data-aos-delay={index * 80}
          class="glass rounded-2xl p-6 neon-border hover:border-nexus-cyan/40 transition-all duration-300 group"
        >
          <div class="flex items-center justify-between mb-4">
            <h3 class="text-white font-display font-semibold text-sm tracking-wider">{skill.name}</h3>
            <span class="text-xs font-mono text-nexus-gray">{skill.level}%</span>
          </div>
          <div class="w-full h-1.5 rounded-full bg-white/5 overflow-hidden">
            <div
              class="h-full rounded-full transition-all duration-1000 ease-out relative overflow-hidden"
              style={{
                width: "0%",
                background: `linear-gradient(90deg, ${skill.color}, ${skill.color}88)`,
              }}
            >
              <div class="absolute inset-0 bg-white/20 animate-pulse"></div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const skillBars = document.querySelectorAll("#skills .h-1\\.5 > div");
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          setTimeout(() => {
            entry.target.style.width = entry.target.parentElement.previousElementSibling?.querySelector("span")?.textContent || "0%";
          }, 300);
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.3 }
  );
  skillBars.forEach((bar) => observer.observe(bar));
</script>
