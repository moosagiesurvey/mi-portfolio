---
import ProjectCard from "./ProjectCard.astro";

const projects = [
  {
    title: "Project Nebula",
    description: "Real-time analytics dashboard with live crypto prices (CoinGecko), GitHub repo stats, and 4 scenario simulators (SaaS, E-commerce, Blog). CSV export, threshold alerts, date filters, multi-view.",
    tags: ["React", "Chart.js", "CoinGecko", "GitHub API"],
    url: "https://mi-nebula.netlify.app",
    gradient: "linear-gradient(135deg, #00f0ff, #7b2ff7)",
  },
  {
    title: "Quantum Forge",
    description: "AI-powered code generator — describe what you want and watch production-ready code materialize with a typing animation.",
    tags: ["React", "TypeScript", "Vite"],
    url: "https://mi-quantum-forge.netlify.app",
    gradient: "linear-gradient(135deg, #ff00e5, #7b2ff7)",
  },
  {
    title: "CyberVault",
    description: "Zero-knowledge encrypted file storage with upload/download management, simulated AES-256-GCM encryption, and real-time sync.",
    tags: ["React", "WebCrypto", "TypeScript"],
    url: "https://mi-cybervault.netlify.app",
    gradient: "linear-gradient(135deg, #7b2ff7, #00f0ff)",
  },
  {
    title: "Aether Terminal",
    description: "Fully interactive web-based terminal emulator with command history, autocomplete, easter eggs, and a custom shell.",
    tags: ["React", "TypeScript", "Xterm.js"],
    url: "https://mi-aether-terminal.netlify.app",
    gradient: "linear-gradient(135deg, #00f0ff, #ff00e5)",
  },
  {
    title: "SynthOS",
    description: "Synthetic OS simulation — draggable windows, taskbar, desktop icons, and window management running entirely in the browser.",
    tags: ["React", "TypeScript", "CSS"],
    url: "https://mi-synth-os.netlify.app",
    gradient: "linear-gradient(135deg, #ff00e5, #00f0ff)",
  },
  {
    title: "Nova API",
    description: "GraphQL API gateway playground with schema browser, query editor, mock responses, and latency tracking.",
    tags: ["GraphQL", "React", "TypeScript"],
    url: "https://mi-nova-api.netlify.app",
    gradient: "linear-gradient(135deg, #7b2ff7, #ff00e5)",
  },
];
---

<section id="projects" class="relative py-24 md:py-32 px-6">
  <div class="max-w-6xl mx-auto">
    <div data-aos="fade-up" class="text-center mb-16">
      <span class="text-nexus-cyan text-sm tracking-widest font-medium mb-4 block">✦ PROJECTS</span>
      <h2 class="text-4xl md:text-5xl font-display font-bold text-white mb-4">
        Featured <span class="gradient-text">Creations</span>
      </h2>
      <p class="text-nexus-gray max-w-xl mx-auto">
        Each project is crafted with precision and purpose. Click to explore live demos.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {projects.map((project, index) => (
        <div data-aos="fade-up" data-aos-delay={index * 100}>
          <ProjectCard {...project} />
        </div>
      ))}
    </div>
  </div>
</section>
