---
export interface Props {
  title: string;
  description: string;
  tags: string[];
  url: string;
  gradient: string;
}

const { title, description, tags, url, gradient } = Astro.props;
---

<a
  href={url}
  target="_blank"
  rel="noopener noreferrer"
  class="project-card group relative glass rounded-2xl p-6 md:p-8 neon-border overflow-hidden transition-all duration-500 hover:-translate-y-2 block"
>
  <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500" style={`background: radial-gradient(600px circle at var(--mouse-x, 50%) var(--mouse-y, 50%), ${gradient}, transparent 40%);`}></div>

  <div class="relative z-10">
    <div class="flex items-center gap-3 mb-6">
      <div class="w-10 h-10 rounded-lg flex items-center justify-center text-lg font-bold font-display" style={`background: ${gradient};`}>
        <span class="text-white">{title.charAt(0)}</span>
      </div>
      <div class="h-px flex-1 bg-gradient-to-r from-white/10 to-transparent"></div>
    </div>

    <h3 class="text-xl md:text-2xl font-display font-bold text-white mb-3 group-hover:gradient-text transition-all duration-300">
      {title}
    </h3>

    <p class="text-nexus-gray text-sm md:text-base leading-relaxed mb-6">
      {description}
    </p>

    <div class="flex flex-wrap gap-2 mb-6">
      {tags.map((tag) => (
        <span class="px-3 py-1 text-xs font-medium rounded-full border border-white/10 text-nexus-gray bg-white/5">
          {tag}
        </span>
      ))}
    </div>

    <div class="flex items-center gap-2 text-nexus-cyan text-sm font-medium group-hover:gap-4 transition-all duration-300">
      <span>View Live</span>
      <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </div>
  </div>
</a>

<script>
  document.querySelectorAll(".project-card").forEach((card) => {
    card.addEventListener("mousemove", (e) => {
      const rect = card.getBoundingClientRect();
      card.style.setProperty("--mouse-x", e.clientX - rect.left + "px");
      card.style.setProperty("--mouse-y", e.clientY - rect.top + "px");
    });
  });
</script>
